# Copy to .env for local development. Never commit a real .env.

# HTTP port the Nest app listens on.
PORT=3000

# development | production | test
NODE_ENV=development

# Postgres connection string consumed by TypeORM. In Docker Compose this should
# point at the postgres service's hostname (e.g. `db`), not localhost.
DATABASE_URL=postgres://logbook:logbook@localhost:5432/logbook

# Local-disk root for uploaded attachment files (LocalDiskStorageService).
# Swap the storage.module.ts binding for an S3-compatible implementation later
# without changing this variable's meaning (still "where files live").
UPLOAD_DIR=./uploads

# Max accepted upload size, in bytes. Defaults to 10MB.
MAX_UPLOAD_SIZE_BYTES=10485760

# scrypt hash of the single-user login password (see src/auth/password-hasher.service.ts).
# Never put the plaintext password in an env var — generate this with:
#   npm run hash-password -- "<your password>"
# The value below hashes "logbook-dev-password" and is for local dev only;
# generate your own for anything beyond a throwaway local environment.
AUTH_PASSWORD_HASH=scrypt$16384$02e6cd9dd6b706bead3e739e83d73e71$6b74546315b091b7565f7d9029a90846810970100d632e700e6cdb40261b4de7997457fefdb3d1765b8c269bf05bece95f5d19c78af4597683f4db2c9362ae23

# How long a session cookie lives before it expires, in days. Renewed
# (slid forward) on use once less than half this TTL remains — see
# src/auth/sessions.service.ts. Deliberately long (default 30 days) so a
# multi-day offline field trip doesn't strand the client's write queue
# behind an expired session at reconnect. Defaults to 30 if unset.
SESSION_TTL_DAYS=30

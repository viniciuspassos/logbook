#!/usr/bin/env bash
# Enforce Conventional Commits on the subject line.
# Installed via `git config core.hooksPath .githooks` (see package.json "prepare" script).
commit_msg_file="$1"
subject=$(head -n1 "$commit_msg_file")

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9./_-]+\))?!?: .+'

if ! [[ "$subject" =~ $pattern ]]; then
  echo "[commit-msg] rejected: \"$subject\"" >&2
  echo "[commit-msg] expected Conventional Commits format: <type>(<scope>)?: <description>" >&2
  echo "[commit-msg] types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert" >&2
  exit 1
fi
